# Copy this file to .env.local (gitignored, never committed) and fill in
# real values from a JIRA SANDBOX/test project. Never point this at
# production JIRA — see CLAUDE.md's "Environments and secrets".

# Anthropic API (used by packages/anthropic-client, in-process from
# apps/classifier and apps/research)
ANTHROPIC_API_KEY=

# JIRA Cloud, API-token auth (sooperset/mcp-atlassian sidecar) — sandbox
# project only
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=

# Coordinator -> mcp-atlassian sidecar. Default already matches
# docker-compose.yml's service name; only override for non-compose local
# runs (e.g. `npm run dev` against a manually-started sidecar).
MCP_ATLASSIAN_URL=http://mcp-atlassian:8000/mcp
