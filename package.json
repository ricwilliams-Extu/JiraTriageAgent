{
  "name": "jira-triage-agent",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "3-tier agent system that triages incoming JIRA tickets automatically.",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build -w apps/dashboard",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -b && npm run typecheck -w apps/dashboard"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.10"
  }
}
